# HostPulse — environment template
#
# Copy to `.env.development` (local dev) or `.env.production` (prod build).
# Lovable Cloud injects backend values automatically; the entries below are
# the ones you may want to override locally or in self-hosted deployments.

# ───────────────────────────────────────────────
# Public (shipped to the browser — VITE_-prefixed)
# ───────────────────────────────────────────────

# Lovable Cloud / Supabase Data API endpoint.
VITE_SUPABASE_URL="https://<your-project-ref>.supabase.co"

# Publishable (anon) key. Safe to expose — RLS enforces access.
VITE_SUPABASE_PUBLISHABLE_KEY="<publishable-anon-key>"

VITE_SUPABASE_PROJECT_ID="<your-project-ref>"

# Stripe/Lovable Payments client token (publishable). Test token in dev,
# live token in prod. The value MUST start with `test_` or `live_`.
VITE_PAYMENTS_CLIENT_TOKEN="test_xxxxxxxxxxxxxxxxxxxxxxxxxx"

# ───────────────────────────────────────────────
# Server-only (NEVER prefix with VITE_)
# ───────────────────────────────────────────────
# These are read inside server functions / route handlers via process.env.
# In Lovable Cloud they are managed as project secrets; locally they live in
# .env.development. Do not commit real values.

# SUPABASE_URL="https://<your-project-ref>.supabase.co"
# SUPABASE_PUBLISHABLE_KEY="<publishable-anon-key>"

# Webhook signing secrets — required by /api/public/* handlers.
# WEBHOOK_SECRET="<random-hex>"

# ───────────────────────────────────────────────
# CI / Playwright (optional)
# ───────────────────────────────────────────────
# PLAYWRIGHT_BASE_URL="http://localhost:8080"
# PLAYWRIGHT_PORT="8080"
